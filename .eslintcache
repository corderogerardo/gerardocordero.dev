.com/i18next/i18next-browser-languageDetector\n  .use(LanguageDetector)\n  // pass the i18n instance to react-i18next.\n  .use(initReactI18next) // passes i18n down to react-i18next\n  .init({\n    fallbackLng: \"en\",\n    debug: true,\n    lng: \"en\",\n\n    keySeparator: false, // we do not use keys in form messages.welcome\n\n    interpolation: {\n      escapeValue: false, // react already safes from xss\n    },\n  });\n\nexport default i18n;\n",["53","54"],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/serviceWorker.ts",[],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/App.tsx",[],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/Landing/Landing.tsx",["55"],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/Landing/Abouts/Container.tsx",["56"],"import React from \"react\";\nimport styled from \"styled-components\";\n\nimport MenuAbout from \"./Menu\";\nimport BodyAbout from \"./Body\";\n\nconst Container = () => {\n  return (\n    <div>\n      <MenuAbout></MenuAbout>\n      <BodyAbout></BodyAbout>\n    </div>\n  );\n};\nexport default React.memo(Container);\n","/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/Landing/Abouts/Body.tsx",[],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/Landing/Abouts/Menu.tsx",[],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/Experiments/TailwindCSS/TailwindCSS.tsx",[],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/Components/NotFound404.tsx",[],"/Volumes/ssd/gerardocordero.dev/gerardocordero.dev/src/ReactTests/EffectWithInterval.tsx",["57"],{"ruleId":"58","replacedBy":"59"},{"ruleId":"60","replacedBy":"61"},{"ruleId":"62","severity":1,"message":"63","line":8,"column":7,"nodeType":"64","messageId":"65","endLine":8,"endColumn":16},{"ruleId":"58","replacedBy":"59"},{"ruleId":"60","replacedBy":"61"},{"ruleId":"66","severity":1,"message":"67","line":6,"column":8,"nodeType":"64","messageId":"65","endLine":6,"endColumn":26},{"ruleId":"66","severity":1,"message":"68","line":2