{
  "name": "@gerardocordero/portfolio",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "dev": "expo start --dev-client",
    "dev:web": "expo start -c --web",
    "dev:ios": "expo run:ios",
    "dev:android": "expo run:android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild --clean",
    "postinstall": "tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.0",
    "@expo/vector-icons": "^15.0.3",
    "@gerardocordero/ui": "workspace:*",
    "@huggingface/transformers": "^4.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-application": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "nativewind": "~4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "tailwindcss": "~3.4.14",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  }
}
