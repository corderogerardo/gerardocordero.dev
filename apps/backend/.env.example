# Required. Secret used to sign JWTs — no default, the app refuses to start
# without it.
PAWWALK_JWT_SECRET=

# Optional — defaults shown.
# PAWWALK_JWT_ALG=HS256
# PAWWALK_JWT_EXPIRE_MINUTES=10080
# PAWWALK_DATABASE_URL=sqlite:///./pawwalk.db

# Which model Pydantic AI should use, e.g. openai:gpt-4o-mini
PAWWALK_LLM_MODEL=

# Stripe (optional — omit and payments/webhooks return stubs, see README).
# PAWWALK_STRIPE_SECRET_KEY=
# PAWWALK_STRIPE_WEBHOOK_SECRET=
